{
  "name": "brand-icons",
  "version": "0.0.0",
  "private": true,
  "description": "Multi-variant, multi-framework brand icons library.",
  "author": "Bryan Berger <contact@bryanberger.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bryanbergerprojects/brand-icons.git"
  },
  "homepage": "https://brand-icons.com",
  "bugs": {
    "url": "https://github.com/bryanbergerprojects/brand-icons/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build",
    "build:icons": "turbo run build --filter=@brand-icons/build-icons",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:md": "markdownlint-cli2",
    "lint:md:fix": "markdownlint-cli2 --fix",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "render:svg": "node tools/render-svg/render.mjs",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build --filter='./packages/*' && changeset publish",
    "release:canary": "gh workflow run release.yml --ref canary",
    "deploy:docs": "gh workflow run deploy-docs.yml --ref main",
    "deploy:docs:canary": "gh workflow run deploy-docs.yml --ref canary",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@changesets/cli": "^2.27.0",
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "husky": "^9.1.7",
    "markdownlint-cli2": "^0.18.0",
    "turbo": "^2.5.0",
    "typescript": "^5.7.0",
    "validate-branch-name": "^1.3.2"
  },
  "validate-branch-name": {
    "pattern": "^(main|canary)$|^(feat|fix|docs|refactor|perf|test|build|ci|chore|revert|add-icon)/[a-z0-9][a-z0-9-]*$",
    "errorMsg": "Invalid branch name. Use `main`, `canary`, or `{type}/{slug-or-scope}` kebab-case — e.g. `add-icon/linear`, `feat/playground-color-picker`, `fix/svgo-strip-style`. Types: feat fix docs refactor perf test build ci chore revert add-icon."
  }
}
