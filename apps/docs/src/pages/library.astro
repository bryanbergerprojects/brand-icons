---
import LibraryGrid from '@/features/library/library-grid';
import BaseLayout from '@/layouts/base.astro';
import { manifest } from '@brand-icons/core';

const sortedIcons = [...manifest].sort((a, b) => a.name.localeCompare(b.name));
---

<BaseLayout
  title="Library — Brand Icons"
  description={`Browse ${sortedIcons.length} brand icons across categories. Search, filter, and copy code for React, Vue, Svelte.`}
>
  <LibraryGrid icons={sortedIcons} client:load />
</BaseLayout>
