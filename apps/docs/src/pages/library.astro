---
import BaseLayout from '@/layouts/base.astro';
import { latestIconBySlug } from '@/lib/all-icons';
import { manifest } from '@brand-icons/core';

const sortedIcons = [...manifest].sort((a, b) => a.name.localeCompare(b.name));
---

<BaseLayout title="Library — Brand Icons" description="Browse every brand icon — color and monochrome variants across all millésimes.">
  <section class="mx-auto max-w-6xl px-6 py-16">
    <header class="border-b border-ink/10 pb-8">
      <p class="font-mono text-xs uppercase tracking-widest text-ink-muted">
        Library · {manifest.length} brands
      </p>
      <h1 class="mt-4 text-4xl font-medium tracking-tight sm:text-5xl">All brand icons</h1>
      <p class="mt-4 max-w-2xl text-ink-muted">
        Color and monochrome variants for every brand, with year-aware millésimes where the
        logo has evolved. Interactive search and filters arrive in the next phase.
      </p>
    </header>

    <ul class="mt-10 grid grid-cols-2 gap-px bg-ink/10 sm:grid-cols-3 lg:grid-cols-4">
      {
        sortedIcons.map((icon) => {
          const Icon = latestIconBySlug[icon.slug];
          return (
            <li class="bg-paper">
              <a
                href={`/icon/${icon.slug}`}
                class="group flex h-full flex-col gap-4 p-6 transition-colors hover:bg-surface-muted"
              >
                <div class="flex h-16 items-center justify-start">
                  {Icon ? <Icon size={48} /> : <span class="text-ink-muted">{icon.name}</span>}
                </div>
                <div class="flex flex-col gap-1">
                  <span class="font-medium">{icon.name}</span>
                  <span class="font-mono text-xs uppercase tracking-widest text-ink-muted">
                    {icon.category}
                  </span>
                </div>
              </a>
            </li>
          );
        })
      }
    </ul>
  </section>
</BaseLayout>
