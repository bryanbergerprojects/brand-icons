---
import Changelog from '@/components/docs/changelog.astro';
import Install from '@/components/docs/install.astro';
import Props from '@/components/docs/props.astro';
import TreeShaking from '@/components/docs/tree-shaking.astro';
import Usage from '@/components/docs/usage.astro';
import Toc from '@/features/docs/toc';
import BaseLayout from '@/layouts/base.astro';
import { CORE_VERSION } from '@/lib/version';
---

<BaseLayout
  title="Docs — Brand Icons"
  description="Install, integrate, theme and tree-shake Brand Icons in any framework. React 19, Vue 3.5, Svelte 5, Web Components. ESM-only."
>
  <section class="border-b border-ink px-10 pt-18 pb-8">
    <div class="flex items-center gap-3 font-mono text-mono font-bold uppercase tracking-meta text-ink-soft">
      <span class="text-accent">—</span>
      <span>·</span>
      <span>Documentation</span>
      <span>·</span>
      <span>v{CORE_VERSION}</span>
      <span>·</span>
      <span>5 chapters</span>
    </div>
    <h1 class="m-0 mt-6 text-h1-2xl font-extrabold tracking-display-xl">Docs<span class="text-accent">.</span></h1>
    <p class="mt-6 max-w-155 text-lg font-normal leading-snug text-ink-soft-2">
      Everything you need to ship Brand Icons. Install, integrate, ship a smaller bundle, keep up
      with releases.
    </p>
  </section>

  <div class="grid grid-cols-[280px_1fr] border-b border-ink">
    <Toc client:idle version={CORE_VERSION} />
    <div class="border-l border-ink bg-paper">
      <div class="container mx-0 px-15 py-10 pb-15">
        <Install />
        <Usage />
        <Props />
        <TreeShaking />
        <Changelog />
      </div>
    </div>
  </div>
</BaseLayout>
