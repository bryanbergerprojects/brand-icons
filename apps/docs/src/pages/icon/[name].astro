---
import Playground, { type PlaygroundYear } from '@/features/playground/playground';
import YearVariants, { type YearVariantEntry } from '@/features/year-variants/year-variants';
import BaseLayout from '@/layouts/base.astro';
import { brands, type IconBrand, manifest, type ManifestEntry } from '@brand-icons/core';

const sortedManifest = [...manifest].sort((a, b) => a.name.localeCompare(b.name));

export const getStaticPaths = () =>
  manifest.map((icon) => ({ params: { name: icon.slug }, props: { icon } }));

const { icon } = Astro.props as { icon: ManifestEntry };

const slugToCamel = (slug: string): string => slug.replace(/-([a-z0-9])/g, (_, c: string) => c.toUpperCase());
const nameToPascal = (name: string): string =>
  name
    .split(/[^a-zA-Z0-9]+/)
    .filter(Boolean)
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join('');

const brand = (brands as Record<string, IconBrand>)[slugToCamel(icon.slug)];
if (!brand) throw new Error(`Missing brand module for slug: ${icon.slug}`);

const capitalize = (slug: string): string => slug.charAt(0).toUpperCase() + slug.slice(1);
const componentName = nameToPascal(icon.name);

const indexInSorted = sortedManifest.findIndex((entry) => entry.slug === icon.slug);
const id = String(indexInSorted + 1).padStart(4, '0');

const formatCategory = (category: string): string =>
  category
    .split('-')
    .map((part) => capitalize(part))
    .join(' ');

const familyLabel = formatCategory(icon.category);

const playgroundYears: readonly PlaygroundYear[] = icon.years
  .map((summary) => {
    const yearBrand = brand.years[summary.year];
    if (!yearBrand) throw new Error(`Brand ${icon.slug} missing year entry ${summary.year}`);
    return {
      year: summary.year,
      mono: yearBrand.mono,
      color: yearBrand.color,
      palette: yearBrand.palette,
    };
  })
  .sort((a, b) => a.year.localeCompare(b.year));

const brandRecord = brands as Record<string, IconBrand>;

const namespaceSvgIds = ({ raw, prefix }: { raw: string; prefix: string }): string => {
  const ids = new Set<string>();
  const idPattern = /\sid="([^"]+)"/g;
  let match: RegExpExecArray | null;
  match = idPattern.exec(raw);
  while (match !== null) {
    if (match[1]) ids.add(match[1]);
    match = idPattern.exec(raw);
  }
  let out = raw;
  for (const id of ids) {
    const escaped = id.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    out = out.replace(new RegExp(`\\sid="${escaped}"`, 'g'), ` id="${prefix}-${id}"`);
    out = out.replace(new RegExp(`url\\(#${escaped}\\)`, 'g'), `url(#${prefix}-${id})`);
    out = out.replace(new RegExp(`href="#${escaped}"`, 'g'), `href="#${prefix}-${id}"`);
    out = out.replace(new RegExp(`xlink:href="#${escaped}"`, 'g'), `xlink:href="#${prefix}-${id}"`);
  }
  return out;
};

const yearVariantEntries: readonly YearVariantEntry[] = playgroundYears.map((entry) => {
  const summary = icon.years.find((y) => y.year === entry.year);
  return {
    year: entry.year,
    colorSvg: namespaceSvgIds({ raw: entry.color, prefix: `yv-${icon.slug}-${entry.year}` }),
    palette: entry.palette,
    ...(summary?.notes ? { notes: summary.notes } : {}),
  };
});

type RelatedCard = {
  readonly slug: string;
  readonly name: string;
  readonly color: string;
  readonly index: string;
};

const related: readonly RelatedCard[] = sortedManifest
  .filter((entry) => entry.slug !== icon.slug && entry.category === icon.category)
  .slice(0, 20)
  .map((entry) => {
    const relatedBrand = brandRecord[slugToCamel(entry.slug)];
    if (!relatedBrand) throw new Error(`Missing brand module for slug: ${entry.slug}`);
    const yearEntry = relatedBrand.years[entry.latest];
    if (!yearEntry) throw new Error(`Brand ${entry.slug} missing year entry ${entry.latest}`);
    const idx = sortedManifest.findIndex((m) => m.slug === entry.slug);
    return {
      slug: entry.slug,
      name: entry.name,
      color: namespaceSvgIds({ raw: yearEntry.color, prefix: `mf-${entry.slug}` }),
      index: String(idx + 1).padStart(4, '0'),
    };
  });

const allCategories = [...new Set(sortedManifest.map((entry) => entry.category))].sort();
const peerCategories = allCategories.filter((cat) => cat !== icon.category);

const categoryQuery = (cat: string): string => `/library?q=${encodeURIComponent(cat)}`;
---

<BaseLayout
  title={`${icon.name} icon — Brand Icons`}
  description={`${icon.name} icon · ${familyLabel} category · ${sortedManifest.length} icons in Brand Icons library. Copy code for React, Vue, Svelte, SVG.`}
>
  <section class="border-b border-ink px-10 py-10">
    <nav aria-label="Breadcrumb" class="mb-4.5 flex items-center gap-2 font-mono text-mono font-semibold uppercase tracking-uppercase text-ink-soft">
      <a href="/library" class="hover:text-accent">Library</a>
      <span aria-hidden>/</span>
      <a href={categoryQuery(icon.category)} class="hover:text-accent">{familyLabel}</a>
      <span aria-hidden>/</span>
      <span class="text-accent">[{icon.slug}]</span>
    </nav>

    <div class="flex flex-wrap items-baseline justify-between gap-8">
      <h1 class="m-0 text-h1-2xl font-extrabold tracking-display-xl text-ink">{icon.name}</h1>

      <div class="flex flex-wrap gap-x-8 gap-y-3">
        <div>
          <p class="font-mono text-mono font-bold uppercase tracking-uppercase text-ink-soft">Family</p>
          <p class="mt-1 text-sm font-semibold">{familyLabel}</p>
        </div>
        <div>
          <p class="font-mono text-mono font-bold uppercase tracking-uppercase text-ink-soft">ID</p>
          <p class="mt-1 font-mono text-sm font-bold">#{id}</p>
        </div>
        <div>
          <p class="font-mono text-mono font-bold uppercase tracking-uppercase text-ink-soft">Component</p>
          <p class="mt-1 font-mono text-sm font-bold">{componentName}LatestIcon</p>
        </div>
        <div>
          <p class="font-mono text-mono font-bold uppercase tracking-uppercase text-ink-soft">Since</p>
          <p class="mt-1 font-mono text-sm font-bold">2.0.0</p>
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-ink px-10 py-12">
    <div class="max-w-245 mx-auto">
      <Playground
        client:idle
        iconName={icon.name}
        slug={icon.slug}
        id={id}
        componentName={componentName}
        brandColor={icon.brandColor}
        years={playgroundYears}
        defaultYear={icon.latest}
      />
    </div>
  </section>

  {yearVariantEntries.length > 0 ? (
    <section class="border-b border-ink px-10 py-14">
      <div class="max-w-245 mx-auto">
        <YearVariants
          client:visible
          iconName={icon.name}
          slug={icon.slug}
          componentName={componentName}
          entries={yearVariantEntries}
        />
      </div>
    </section>
  ) : null}

  <section class="border-b border-ink bg-paper-warm px-10 py-14">
    <p class="mb-6 flex items-center gap-3 font-mono text-mono font-bold uppercase tracking-meta text-ink-soft">
      <span class="text-accent">—</span>
      <span>Related</span>
      <span>·</span>
      <span>Same category</span>
    </p>
    <h2 class="m-0 text-h3 font-extrabold tracking-display-xs text-ink">
      More from <span class="text-accent">{familyLabel}</span>.
    </h2>

    {related.length === 0 ? (
      <p class="mt-8 text-ink-soft">No siblings in this category yet.</p>
    ) : (
      <div class="mt-8 overflow-hidden border border-ink bg-paper">
        <div class="-mr-px -mb-px grid grid-cols-1 md:grid-cols-5 lg:grid-cols-5">
          {related.map((entry, i) => (
            <a
              href={`/icon/${entry.slug}`}
              class:list={[
                'group related-card relative flex min-h-32 flex-col items-center gap-2.5 border-r border-b border-ink bg-paper px-2 pt-5.5 pb-3.5 text-ink transition-colors hover:bg-paper-alt',
                i >= 5 && i < 10 && 'hidden md:flex',
                i >= 10 && 'hidden lg:flex',
              ]}
            >
              <span class="absolute left-2.5 top-2.5 font-mono text-mono-xs text-ink-soft">#{entry.index}</span>
              <span class="absolute right-2.5 top-2.5 font-mono text-mono-sm text-ink-soft">→</span>
              <span class="related-icon flex h-10 w-10 flex-1 items-center justify-center" set:html={entry.color} />
              <span class="mt-auto font-mono text-mono font-semibold">{entry.name}</span>
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="mt-5.5 px-5.5 py-3.5 flex flex-wrap items-center justify-between gap-4 border border-ink bg-paper">
      <p class="text-13 text-ink-soft-2">
        See all <strong class="font-semibold text-ink">{familyLabel}</strong> icons.
      </p>
      <a
        href={categoryQuery(icon.category)}
        class="px-4.5 tracking-cta bg-accent py-2.5 text-xs font-semibold uppercase text-paper transition-colors hover:bg-ink"
      >
        Open category →
      </a>
    </div>

    {peerCategories.length > 0 ? (
      <div class="mt-9">
        <p class="mb-2.5 font-mono text-mono-sm font-bold uppercase tracking-mono text-ink-soft">Other categories</p>
        <ul class="flex flex-wrap gap-2">
          {peerCategories.map((cat) => (
            <li>
              <a
                href={categoryQuery(cat)}
                class="inline-block border border-ink bg-paper px-3 py-1.5 text-xs font-semibold text-ink transition-colors hover:bg-ink hover:text-paper"
              >
                {formatCategory(cat)}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ) : null}
  </section>
</BaseLayout>

<style>
  .related-icon :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
