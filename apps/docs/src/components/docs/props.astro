---
import H from '@/components/docs/section-heading.astro';

type PropRow = {
  name: string;
  type: string;
  default: string;
  desc: string;
};

const ROWS: readonly PropRow[] = [
  { name: 'size', type: 'number | string', default: '24', desc: 'Outer width and height in px.' },
  {
    name: 'weight',
    type: '"outline" | "solid" | "duotone" | "sketch"',
    default: '"outline"',
    desc: 'Stroke / fill style.',
  },
  {
    name: 'year',
    type: 'number',
    default: 'current',
    desc: 'Pin a specific era. Falls back to the closest available year.',
  },
  { name: 'stroke', type: 'CSSColor', default: 'currentColor', desc: 'Stroke colour.' },
  {
    name: 'strokeWidth',
    type: 'number',
    default: '1.5',
    desc: 'Line thickness in pt. Range 1 → 2.5.',
  },
  {
    name: 'title',
    type: 'string',
    default: 'undefined',
    desc: 'Sets <title> and role="img".',
  },
  { name: 'className', type: 'string', default: '""', desc: 'Forwarded to the <svg> root.' },
];

const HEADER_CELL =
  'border-r border-white/15 bg-ink px-3.5 py-2.5 font-mono text-mono-sm font-bold uppercase tracking-tab text-paper last:border-r-0';
const BODY_BASE = 'border-t border-paper-alt border-r border-paper-alt px-3.5 py-3 last:border-r-0';
---

<section class="border-t border-ink pt-18 pb-18">
  <H id="props" num="03" kicker="Props" title="Seven props. No surprises." />

  <p class="text-base text-ink-soft-2">
    Every icon component accepts the same flat prop set. Forward the rest to the
    <code class="bg-paper-alt px-1.5 py-px font-mono">{'<svg>'}</code> root via
    <code class="bg-paper-alt px-1.5 py-px font-mono">className</code>.
  </p>

  <div class="mt-6 grid grid-cols-[180px_280px_140px_1fr] border border-ink text-13">
    <div class={HEADER_CELL}>Prop</div>
    <div class={HEADER_CELL}>Type</div>
    <div class={HEADER_CELL}>Default</div>
    <div class={HEADER_CELL}>Description</div>

    {
      ROWS.map((row, i) => {
        const zebra = i % 2 === 0 ? 'bg-paper-warm' : 'bg-paper';
        return (
          <>
            <div class={`${BODY_BASE} ${zebra} font-mono font-bold text-accent`}>{row.name}</div>
            <div class={`${BODY_BASE} ${zebra} font-mono text-ink`}>{row.type}</div>
            <div class={`${BODY_BASE} ${zebra} font-mono text-ink-soft`}>{row.default}</div>
            <div class={`${BODY_BASE} ${zebra} text-ink`}>{row.desc}</div>
          </>
        );
      })
    }
  </div>
</section>
