---
import H from '@/components/docs/section-heading.astro';

type PropRow = {
  name: string;
  type: string;
  default: string;
  desc: string;
};

const ROWS: readonly PropRow[] = [
  {
    name: 'size',
    type: 'number | string',
    default: '"1em"',
    desc: 'Width and height. Number → px, string → any CSS length.',
  },
  {
    name: 'variant',
    type: '"color" | "mono"',
    default: '"color"',
    desc: 'Render the official multi-color or monochrome variant.',
  },
  {
    name: 'color',
    type: 'string',
    default: 'undefined',
    desc: 'Override currentColor on mono fills when mode="mono".',
  },
  {
    name: 'mode',
    type: '"as-is" | "bw" | "wb" | "mono"',
    default: '"as-is"',
    desc: 'Color transform — bw: grayscale, wb: inverted, mono: force mono variant.',
  },
  {
    name: 'background',
    type: 'boolean | string',
    default: 'undefined',
    desc: 'Paint a rect behind the icon. true → brand color, string → any CSS color.',
  },
  {
    name: 'title',
    type: 'string',
    default: 'undefined',
    desc: 'Sets <title> and role="img" on the <svg> root.',
  },
  { name: 'className', type: 'string', default: 'undefined', desc: 'Forwarded to the <svg> root.' },
];

const HEADER_CELL =
  'border-r border-white/15 bg-ink px-3.5 py-2.5 font-mono text-mono-sm font-bold uppercase tracking-tab text-paper last:border-r-0';
const BODY_BASE = 'border-t border-paper-alt border-r border-paper-alt px-3.5 py-3 last:border-r-0';
---

<section class="border-t border-ink pt-12 pb-12 sm:pt-14 sm:pb-14 lg:pt-18 lg:pb-18">
  <H id="props" num="03" kicker="Props" title="Seven props. No surprises." />

  <p class="text-base text-ink-soft-2">
    Every icon component accepts the same flat prop set. The historical millésime is encoded in the
    component name itself — e.g.
    <code class="bg-paper-alt px-1.5 py-px font-mono">{'<Apple1976Icon />'}</code> vs
    <code class="bg-paper-alt px-1.5 py-px font-mono">{'<Apple1998Icon />'}</code> — not a runtime
    prop, so unused millésimes tree-shake away.
  </p>

  <div class="mt-6 overflow-x-auto border border-ink">
    <div class="grid min-w-[760px] grid-cols-[180px_280px_140px_1fr] text-13">
    <div class={HEADER_CELL}>Prop</div>
    <div class={HEADER_CELL}>Type</div>
    <div class={HEADER_CELL}>Default</div>
    <div class={HEADER_CELL}>Description</div>

    {
      ROWS.map((row, i) => {
        const zebra = i % 2 === 0 ? 'bg-paper-warm' : 'bg-paper';
        return (
          <>
            <div class={`${BODY_BASE} ${zebra} font-mono font-bold text-accent`}>{row.name}</div>
            <div class={`${BODY_BASE} ${zebra} font-mono text-ink`}>{row.type}</div>
            <div class={`${BODY_BASE} ${zebra} font-mono text-ink-soft`}>{row.default}</div>
            <div class={`${BODY_BASE} ${zebra} text-ink`}>{row.desc}</div>
          </>
        );
      })
    }
    </div>
  </div>
</section>
