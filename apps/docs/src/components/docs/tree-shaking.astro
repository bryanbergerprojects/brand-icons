---
import { manifest } from '@brand-icons/core';
import CodeBlock from '@/components/docs/code-block.astro';
import H from '@/components/docs/section-heading.astro';

type Stat = { num: string; count: string; label: string; size: string };

// Measured 2026-05-17 with esbuild 0.27 — minified, ESM, react/react-dom external,
// gzip level 9. Per-icon average derived from the 47-brand bundle (~0.85 kB / icon
// gzip), baseline ~1 kB for runtime + shared utils.
const BASELINE_KB = 1.8;
const PER_ICON_KB = 0.85;

const brandCount = manifest.length;
const entryCount = manifest.reduce((sum, entry) => sum + entry.years.length, 0);

const fmtKb = (kb: number): string => (kb < 10 ? `${kb.toFixed(1)} kB` : `${Math.round(kb)} kB`);
const sizeFor = (n: number): string => fmtKb(BASELINE_KB + Math.max(0, n - 1) * PER_ICON_KB);

const STATS: readonly Stat[] = [
  { num: '01.', count: '1', label: 'icon', size: sizeFor(1) },
  { num: '02.', count: '10', label: 'icons', size: sizeFor(10) },
  {
    num: '03.',
    count: brandCount.toString(),
    label: brandCount === 1 ? 'brand · latest' : 'brands · latest',
    size: sizeFor(brandCount),
  },
  {
    num: '04.',
    count: entryCount.toString(),
    label: 'every millésime',
    size: sizeFor(entryCount),
  },
];

const GOOD_SOURCE = `import { GitHubLatestIcon, NotionLatestIcon } from '@brand-icons/react';
// bundler keeps only the two icons + shared runtime`;

const AVOID_SOURCE = `import * as Icons from '@brand-icons/react';
// referencing the namespace defeats tree-shaking — every icon ships`;
---

<section class="border-t border-ink pt-12 pb-12 sm:pt-14 sm:pb-14 lg:pt-18 lg:pb-18">
  <H id="tree" num="04" kicker="Tree shaking" title="Pay for what you render." />

  <p class="text-base text-ink-soft-2">
    Every package ships as ESM with <code class="bg-paper-alt px-1.5 py-px font-mono"
      >"sideEffects": false</code
    > and one entry per icon. Bundlers (esbuild, Rollup, Vite, Webpack 5, Rspack) drop every
    icon you don't import — sizes below are minified + gzip.
  </p>

  <div class="mt-6 grid grid-cols-2 border-t border-l border-ink bg-paper lg:grid-cols-4">
    {
      STATS.map((s) => (
          <div class="border-r border-b border-ink p-5 px-5.5">
            <span class="font-mono text-mono-sm font-bold tracking-mono text-accent">{s.num}</span>
            <div class="mt-2 text-stat font-extrabold leading-none tracking-display-sm tabular-nums">
              {s.count}
            </div>
            <div class="mt-1.5 text-xs text-ink-soft">{s.label}</div>
            <div class="mt-2 font-mono text-mono font-bold text-ink">{s.size}</div>
          </div>
        ))
    }
  </div>

  <p class="mt-3 font-mono text-mono-xs text-ink-soft">
    // measured with esbuild · react + react-dom external · brotli ≈ 20% lower
  </p>

  <div class="mt-6 grid grid-cols-1 gap-5 md:grid-cols-2">
    <div>
      <p class="mb-2 font-mono text-mono-sm font-bold uppercase tracking-mono text-kind-fix">
        Good — granular import
      </p>
      <CodeBlock lang="ok" source={GOOD_SOURCE} />
    </div>
    <div>
      <p class="mb-2 font-mono text-mono-sm font-bold uppercase tracking-mono text-accent">
        Avoid — namespace import
      </p>
      <CodeBlock lang="warn" source={AVOID_SOURCE} />
    </div>
  </div>
</section>
