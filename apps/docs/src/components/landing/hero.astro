---
import { buttonVariants } from '@/components/ui/button';
import Playground, { type PlaygroundYear } from '@/features/playground/playground';
import LiveCounter from '@/features/landing/live-counter';
import TimelineBackdrop from '@/features/landing/timeline-backdrop';
import { brands, type IconBrand, manifest } from '@brand-icons/core';
import { CORE_VERSION } from '@/lib/version';

const apple = (brands as Record<string, IconBrand>).apple;
if (!apple) throw new Error('Missing brand module for slug: apple');

const iconCount = manifest.length;

const appleYears: readonly PlaygroundYear[] = Object.entries(apple.years)
  .map(([year, data]) => ({
    year,
    mono: data.mono,
    color: data.color,
    palette: data.palette,
  }))
  .sort((a, b) => a.year.localeCompare(b.year));
---

<section data-hero-section class="relative overflow-hidden">
  <TimelineBackdrop client:load />

  <div class="container relative z-10 mx-auto px-10 pt-14 pb-20">
    <div class="grid grid-cols-[1.25fr_1fr] gap-12">
      <div>
        <h1 class="m-0 text-h1 font-extrabold tracking-display-sm">
          Every brand.<br />Every era.<br />One <span class="text-accent">library</span>.
        </h1>

        <p class="mt-7 max-w-130 text-lg font-normal text-ink-soft-2">
          From Apple's 1977 logo to yesterday's rebrand. In one line of code.
        </p>

        <div class="mt-9 flex h-11 items-stretch gap-3.5">
          <button
            type="button"
            data-open-command-palette
            aria-label="Search an icon"
            class="group flex flex-1 items-center gap-3.5 border-thin border-ink bg-paper pl-4.5 pr-1 py-1 text-left outline-none transition-colors hover:bg-paper-alt focus-visible:ring-2 focus-visible:ring-accent"
          >
            <svg
              aria-hidden="true"
              viewBox="0 0 24 24"
              width="20"
              height="20"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-ink-soft"
            >
              <circle cx="11" cy="11" r="7"></circle>
              <path d="m20 20-3.5-3.5"></path>
            </svg>
            <span class="flex-1 text-base font-normal text-ink-soft">
              Search an icon… (e.g. arrow, lock, bell)
            </span>
            <span class="px-3 font-mono text-mono font-semibold whitespace-nowrap text-ink-soft">⌘ K</span>
          </button>
          <a href="/library" class={buttonVariants({ variant: 'accent', size: 'cta', className: 'rounded-none' })}>
            Browse library →
          </a>
        </div>

        <div class="mt-9 flex flex-wrap items-center gap-6">
          <LiveCounter client:visible count={iconCount} />
          <span class="text-xs font-medium text-ink-soft">
            <span class="font-bold text-accent">●</span> Open source · MIT · v{CORE_VERSION}
          </span>
        </div>
      </div>

      <div>
        <Playground
          client:visible
          iconName={apple.name}
          slug={apple.slug}
          componentName="Apple"
          brandColor={apple.brandColor}
          years={appleYears}
          defaultYear={apple.latest}
        />
      </div>
    </div>
  </div>
</section>
