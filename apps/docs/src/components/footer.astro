---
import { CORE_VERSION } from '@/lib/version';
import { manifest } from '@brand-icons/core';

type FooterLink = { href: string; label: string; external?: boolean };

const VERSION = CORE_VERSION;
const BRAND_COUNT = manifest.length;
const GITHUB_URL = 'https://github.com/bryanbergerprojects/brand-icons';

const PRODUCT_LINKS: readonly FooterLink[] = [
  { href: '/library', label: 'Library' },
  { href: '/docs', label: 'Documentation' },
  { href: GITHUB_URL, label: 'GitHub', external: true },
];

const RESOURCE_LINKS: readonly FooterLink[] = [
  { href: '/resources/license', label: 'License' },
  { href: '/resources/code-of-conduct', label: 'Code of conduct' },
  { href: '/resources/contributing', label: 'Contributing' },
  { href: '/resources/brand-owners', label: 'Brand owners' },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-ink text-paper pt-10 pb-8 sm:pt-12 lg:pt-14">
  <div class="container mx-auto px-4 sm:px-6 lg:px-10">
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-[2fr_1fr_1fr] lg:gap-9">
      <div>
        <a href="/" class="inline-block text-4xl font-extrabold tracking-display-sm text-paper">
          Brand<span class="text-accent">·</span>Icons
        </a>
        <p class="mt-3.5 max-w-70 text-13 text-white/70">
          Multi-variant, multi-framework brand icons library. Every brand, every era — in one line of code.
        </p>
        <p class="mt-6 font-mono text-mono-sm tracking-mono text-white/40">
          // v{VERSION} · MIT · {BRAND_COUNT} brands
        </p>
      </div>

      <div>
        <p class="mb-4.5 font-mono text-mono font-bold uppercase tracking-mono text-white/50">
          Product
        </p>
        <ul class="flex flex-row flex-wrap gap-x-5 gap-y-2.5 lg:flex-col lg:gap-2.5">
          {
            PRODUCT_LINKS.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-13 font-medium text-paper transition-colors hover:text-accent"
                  {...(link.external ? { target: '_blank', rel: 'noopener' } : {})}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <p class="mb-4.5 font-mono text-mono font-bold uppercase tracking-mono text-white/50">
          Resources
        </p>
        <ul class="flex flex-row flex-wrap gap-x-5 gap-y-2.5 lg:flex-col lg:gap-2.5">
          {
            RESOURCE_LINKS.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-13 font-medium text-paper transition-colors hover:text-accent"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div
      class="mt-10 flex flex-row items-center justify-between gap-6 border-t border-white/20 pt-6 font-mono text-mono tracking-wider text-white/50 lg:mt-14"
    >
      <p>© {currentYear} Bryan Berger</p>
      <a href="/terms" class="transition-colors hover:text-paper">Terms</a>
    </div>
  </div>
</footer>
