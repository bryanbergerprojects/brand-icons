---
import Footer from '@/components/footer.astro';
import Nav from '@/components/nav.astro';
import CommandPalette, { type DocLink } from '@/features/command-palette/command-palette';
import { manifest } from '@brand-icons/core';
import '@/styles/global.css';

type Props = {
  title: string;
  description?: string;
};

const { title, description = 'Multi-variant, multi-framework brand icons library.' } = Astro.props;

const sortedIcons = [...manifest].sort((a, b) => a.name.localeCompare(b.name));

const docLinks: readonly DocLink[] = [
  { title: 'Install', href: '/docs#install' },
  { title: 'Usage', href: '/docs#usage' },
  { title: 'Props', href: '/docs#props' },
  { title: 'Tree shaking', href: '/docs#tree' },
  { title: 'Changelog', href: '/docs#changelog' },
  { title: 'License', href: '/resources/license' },
  { title: 'Contributing', href: '/resources/contributing' },
  { title: 'Code of conduct', href: '/resources/code-of-conduct' },
  { title: 'Brand owners', href: '/resources/brand-owners' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon-light.svg" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/svg+xml" href="/favicon-dark.svg" media="(prefers-color-scheme: dark)" />
    <title>{title}</title>
  </head>
  <body class="flex min-h-screen flex-col bg-paper text-ink font-sans antialiased">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <CommandPalette icons={sortedIcons} docs={docLinks} client:idle />
  </body>
</html>
