---
import Footer from '@/components/footer.astro';
import Nav from '@/components/nav.astro';
import '@/styles/global.css';

type Props = {
  title: string;
  description?: string;
};

const { title, description = 'Multi-variant, multi-framework brand icons library.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="flex min-h-screen flex-col bg-paper text-ink font-sans antialiased">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
