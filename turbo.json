{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".astro/**", "!.astro/types.d.ts"],
      "inputs": ["src/**", "public/**", "package.json", "tsconfig.json", "tsup.config.ts", "astro.config.*", "components.json"]
    },
    "@brand-icons/build-icons#build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "templates/**", "package.json", "tsconfig.json", "tsup.config.ts", "../../icons/**"],
      "outputs": ["dist/**", "../../packages/core/src/icons/**", "../../packages/core/src/manifest.ts", "../../packages/react/src/icons/**"]
    },
    "docs#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".astro/**", "!.astro/types.d.ts", "src/generated/**"],
      "inputs": [
        "src/**",
        "public/**",
        "scripts/**",
        "package.json",
        "tsconfig.json",
        "astro.config.*",
        "components.json",
        "../../packages/*/CHANGELOG.md"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
