{
  "name": "@brand-icons/svelte",
  "version": "0.0.0",
  "description": "Svelte 5 components for Brand Icons.",
  "license": "MIT",
  "author": "Bryan Berger <contact@bryanberger.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bryanbergerprojects/brand-icons.git",
    "directory": "packages/svelte"
  },
  "homepage": "https://github.com/bryanbergerprojects/brand-icons/tree/main/packages/svelte",
  "bugs": {
    "url": "https://github.com/bryanbergerprojects/brand-icons/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "svelte": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./icons/*": {
      "types": "./dist/icons/*.d.ts",
      "svelte": "./dist/icons/*.js",
      "import": "./dist/icons/*.js"
    }
  },
  "scripts": {
    "build": "svelte-package",
    "dev": "svelte-package --watch",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@brand-icons/core": "workspace:*"
  },
  "peerDependencies": {
    "svelte": ">=5"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.3.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
