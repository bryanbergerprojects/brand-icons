{
  "name": "@brand-icons/core",
  "version": "0.1.0-canary.0",
  "description": "Core SVG strings, manifest, and types for Brand Icons.",
  "license": "MIT",
  "author": "Bryan Berger <contact@bryanberger.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bryanbergerprojects/brand-icons.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/bryanbergerprojects/brand-icons/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/bryanbergerprojects/brand-icons/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./icons/*": {
      "types": "./dist/icons/*.d.ts",
      "import": "./dist/icons/*.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
